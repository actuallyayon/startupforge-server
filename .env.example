# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=startupforge

# ---- Better Auth ----
# Generate a strong random secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
# Public URL of THIS server (used by Better Auth for callbacks)
BETTER_AUTH_URL=http://localhost:5000

# ---- Client ----
CLIENT_ORIGIN=http://localhost:5173

# ---- Google OAuth (Better Auth social provider) ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- JWT challenge layer ----
JWT_SECRET=replace_with_another_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price (in cents) charged for the founder premium package
PREMIUM_PRICE_CENTS=999

# ---- Admin seed (used by `npm run seed:admin`) ----
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@startupforge.com
ADMIN_PASSWORD=Admin123
